{
  "name": "vet-crm-standalone",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "tsx backend/server.ts",
    "build:frontend": "vite build",
    "build:backend": "esbuild backend/server.ts --bundle --platform=node --target=node22 --outfile=dist/server.js --format=cjs --external:express --external:cors --external:cookie-parser --external:dotenv --external:bcryptjs --external:jsonwebtoken --external:nodemailer --external:multer --external:@prisma/client",
    "build": "npm run build:frontend && npm run build:backend",
    "db:generate": "prisma generate",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^11.18.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "sharp": "^0.34.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
