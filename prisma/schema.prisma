generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(uuid())
  name               String
  email              String          @unique
  password_hash      String
  role               String          @default("PACIENTE")
  failed_attempts    Int             @default(0)
  locked_until       DateTime?
  two_factor_enabled Boolean         @default(false)
  two_factor_secret  String?
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  audit_logs         AuditLog[]
  doctor             Doctor?
  tutor              Tutor?
  password_resets    PasswordReset[]
  two_factor_codes   TwoFactorCode[]

  @@map("users")
}

model PasswordReset {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "vet_password_resets_user_id_fkey")
  @@map("vet_password_resets")
}

model TwoFactorCode {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  code       String
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "vet_two_factor_codes_user_id_fkey")
  @@map("vet_two_factor_codes")
}

model Tutor {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  phone      String
  cep        String?
  address    String
  number     String?
  complement String?
  animals    Animal[]
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tutors")
}

model Doctor {
  id              String          @id @default(uuid())
  userId          String          @unique @map("user_id")
  specialty       String
  crm             String          @unique
  schedule_config String?         @db.Text
  appointments    Appointment[]
  doctor_rooms    DoctorRoom[]
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions   Prescription[]
  requested_exams RequestedExam[]

  @@map("doctors")
}

model Animal {
  id              String          @id @default(uuid())
  tutorId         String          @map("tutor_id")
  name            String
  species         String
  breed           String
  birth_date      DateTime
  weight          Float
  allergies       String?         @db.Text
  photo_url       String?
  tutor           Tutor           @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  prescriptions   Prescription[]
  queue_numbers   QueueNumber[]
  requested_exams RequestedExam[]
  vaccines        Vaccine[]

  @@index([tutorId], map: "animals_tutor_id_fkey")
  @@map("animals")
}

model Room {
  id           String        @id @default(uuid())
  name         String
  sector       String
  appointments Appointment[]
  doctor_rooms DoctorRoom[]
  queue_numbers QueueNumber[]

  @@map("rooms")
}

model DoctorRoom {
  id       String @id @default(uuid())
  doctorId String @map("doctor_id")
  roomId   String @map("room_id")
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  room     Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([doctorId, roomId])
  @@index([roomId], map: "doctor_rooms_room_id_fkey")
  @@map("doctor_rooms")
}

model Appointment {
  id                   String         @id @default(uuid())
  animalId             String         @map("animal_id")
  doctorId             String         @map("doctor_id")
  roomId               String?        @map("room_id")
  appointment_datetime DateTime
  status               String         @default("AGENDADA")
  observation          String?        @db.Text
  animal               Animal         @relation(fields: [animalId], references: [id], onDelete: NoAction)
  doctor               Doctor         @relation(fields: [doctorId], references: [id], onDelete: NoAction)
  room                 Room?          @relation(fields: [roomId], references: [id], onDelete: NoAction)
  prescriptions        Prescription[]
  queue_numbers        QueueNumber[]

  @@index([animalId], map: "appointments_animal_id_fkey")
  @@index([doctorId], map: "appointments_doctor_id_fkey")
  @@index([roomId], map: "appointments_room_id_fkey")
  @@map("appointments")
}

model ExamType {
  id              String          @id @default(uuid())
  name            String          @unique
  description     String?         @db.Text
  schedule_config String?         @db.Text
  requested_exams RequestedExam[]

  @@map("exam_types")
}

model RequestedExam {
  id             String    @id @default(uuid())
  animalId       String    @map("animal_id")
  doctorId       String    @map("doctor_id")
  examTypeId     String    @map("exam_type_id")
  request_date   DateTime  @default(now())
  execution_date DateTime?
  file_path      String?
  result_text    String?   @db.Text
  status         String    @default("SOLICITADO")
  animal         Animal    @relation(fields: [animalId], references: [id], onDelete: NoAction)
  doctor         Doctor    @relation(fields: [doctorId], references: [id], onDelete: NoAction)
  exam_type      ExamType  @relation(fields: [examTypeId], references: [id], onDelete: NoAction)

  @@index([animalId], map: "requested_exams_animal_id_fkey")
  @@index([doctorId], map: "requested_exams_doctor_id_fkey")
  @@index([examTypeId], map: "requested_exams_exam_type_id_fkey")
  @@map("requested_exams")
}

model Prescription {
  id                String                   @id @default(uuid())
  appointmentId     String?                  @map("appointment_id")
  animalId          String                   @map("animal_id")
  doctorId          String                   @map("doctor_id")
  prescription_date DateTime                 @default(now())
  notes             String?                  @db.Text
  file_path         String?
  medications       PrescriptionMedication[]
  animal            Animal                   @relation(fields: [animalId], references: [id], onDelete: NoAction)
  appointment       Appointment?             @relation(fields: [appointmentId], references: [id])
  doctor            Doctor                   @relation(fields: [doctorId], references: [id], onDelete: NoAction)

  @@index([animalId], map: "prescriptions_animal_id_fkey")
  @@index([appointmentId], map: "prescriptions_appointment_id_fkey")
  @@index([doctorId], map: "prescriptions_doctor_id_fkey")
  @@map("prescriptions")
}

model PrescriptionMedication {
  id              String       @id @default(uuid())
  prescriptionId  String       @map("prescription_id")
  medication_name String
  dosage          String
  frequency       String
  duration        String?
  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId], map: "prescription_medications_prescription_id_fkey")
  @@map("prescription_medications")
}

model VaccineType {
  id             String    @id @default(uuid())
  name           String    @unique
  description    String?   @db.Text
  default_dosage String?
  stock          Int       @default(0)
  created_at     DateTime  @default(now())
  vaccines       Vaccine[]

  @@map("vaccine_types")
}

model Vaccine {
  id               String       @id @default(uuid())
  animalId         String       @map("animal_id")
  vaccineTypeId    String?      @map("vaccine_type_id")
  name             String
  dosage           String?
  application_date DateTime     @default(now())
  next_dose_date   DateTime?
  batch            String?
  animal           Animal       @relation(fields: [animalId], references: [id], onDelete: Cascade)
  vaccine_type     VaccineType? @relation(fields: [vaccineTypeId], references: [id])

  @@index([animalId], map: "vaccines_animal_id_fkey")
  @@index([vaccineTypeId], map: "vaccines_vaccine_type_id_fkey")
  @@map("vaccines")
}

model QueueNumber {
  id                  String       @id @default(uuid())
  code                String
  classification      String       @default("GERAL")
  generation_datetime DateTime     @default(now())
  status              String       @default("AGUARDANDO")
  animalId            String?      @map("animal_id")
  animalName          String?      @map("animal_name")
  appointmentId       String?      @map("appointment_id")
  targetType          String?      @map("target_type")
  targetName          String?      @map("target_name")
  roomId              String?      @map("room_id")
  examTypeId          String?      @map("exam_type_id")
  animal              Animal?      @relation(fields: [animalId], references: [id])
  appointment         Appointment? @relation(fields: [appointmentId], references: [id])
  room                Room?        @relation(fields: [roomId], references: [id])

  @@index([animalId], map: "queue_numbers_animal_id_fkey")
  @@index([appointmentId], map: "queue_numbers_appointment_id_fkey")
  @@map("queue_numbers")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  table_name String
  record_id  String
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([userId], map: "audit_logs_user_id_fkey")
  @@map("audit_logs")
}

model ClinicConfig {
  id                    String @id @default("global")
  consultation_interval Int    @default(30)

  @@map("clinic_configs")
}

model api_keys {
  id                Int       @id @default(autoincrement())
  key_name          String    @unique(map: "key_name") @db.VarChar(100)
  api_key           String    @db.Text
  description       String?   @db.VarChar(255)
  active            Boolean?  @default(true)
  selected_model    String?   @db.VarChar(100)
  compatible_models String?   @db.LongText
  last_tested       DateTime? @db.Timestamp(0)
  test_results      String?   @db.LongText
  createdAt         DateTime? @default(now()) @db.Timestamp(0)
  updatedAt         DateTime? @default(now()) @db.Timestamp(0)

  @@index([key_name], map: "idx_key_name")
}

model card_price_history {
  id          Int       @id @default(autoincrement())
  card_id     String    @db.VarChar(100)
  preco_medio Decimal?  @db.Decimal(10, 2)
  menor_preco Decimal?  @db.Decimal(10, 2)
  recorded_at DateTime? @default(now()) @db.Timestamp(0)

  @@index([card_id, recorded_at], map: "idx_card_history")
}

model card_prices {
  id          Int       @id @default(autoincrement())
  card_id     String    @unique(map: "unique_card") @db.VarChar(100)
  card_name   String    @db.VarChar(255)
  collection  String?   @db.VarChar(100)
  liga_url    String    @db.Text
  preco_medio Decimal?  @db.Decimal(10, 2)
  menor_preco Decimal?  @db.Decimal(10, 2)
  qualidade   String?   @default("NM") @db.VarChar(10)
  fonte       String?   @default("ligaPokemon") @db.VarChar(50)
  updated_at  DateTime  @db.DateTime(0)
  created_at  DateTime? @default(now()) @db.Timestamp(0)

  @@index([updated_at], map: "idx_updated")
}

model collections {
  id           Int       @id @default(autoincrement())
  set_id       String    @unique(map: "set_id") @db.VarChar(100)
  nome         String    @db.VarChar(255)
  serie        String?   @db.VarChar(255)
  total_cartas Int?
  release_date String?   @db.VarChar(50)
  logo_url     String?   @db.Text
  symbol_url   String?   @db.Text
  synced_at    DateTime? @default(now()) @db.Timestamp(0)
}

model holerites {
  id               Int       @id @default(autoincrement())
  userId           String?   @db.VarChar(128)
  mesAno           String?   @db.VarChar(10)
  dataRegistro     BigInt?
  salarioBase      Decimal?  @db.Decimal(10, 2)
  horasNormais     String?   @db.LongText
  horasExtras      String?   @db.LongText
  adicionalNoturno String?   @db.LongText
  adicionais       String?   @db.LongText
  descontos        String?   @db.LongText
  dependentes      Int?      @default(0)
  totalVencimentos Decimal?  @db.Decimal(10, 2)
  totalDescontos   Decimal?  @db.Decimal(10, 2)
  valorLiquido     Decimal?  @db.Decimal(10, 2)
  baseFGTS         Decimal?  @db.Decimal(10, 2)
  createdAt        DateTime? @default(now()) @db.Timestamp(0)
  perfis           perfis?   @relation(fields: [userId], references: [uid], onDelete: Cascade, onUpdate: Restrict, map: "holerites_ibfk_1")

  @@index([userId], map: "userId")
}

model lancamentos {
  id              Int               @id @default(autoincrement())
  userId          String?           @db.VarChar(128)
  tipo            lancamentos_tipo?
  descricao       String?           @db.VarChar(255)
  categoria       String?           @db.VarChar(100)
  valor           Decimal?          @db.Decimal(10, 2)
  data            BigInt?
  parcelas        Int?              @default(1)
  metodoPagamento String?           @db.VarChar(100)
  pago            Boolean?          @default(false)
  createdAt       DateTime?         @default(now()) @db.Timestamp(0)
  perfis          perfis?           @relation(fields: [userId], references: [uid], onDelete: Cascade, onUpdate: Restrict, map: "lancamentos_ibfk_1")

  @@index([userId], map: "userId")
}

model password_resets {
  id        Int    @id @default(autoincrement())
  email     String @db.VarChar(255)
  code      String @db.VarChar(6)
  expiresAt BigInt
  attempts  Int?   @default(0)
}

model perfis {
  uid                 String               @id @db.VarChar(128)
  nome                String?              @db.VarChar(255)
  email               String?              @db.VarChar(255)
  empresa             String?              @db.VarChar(255)
  cargo               String?              @db.VarChar(255)
  salarioBase         Decimal?             @db.Decimal(10, 2)
  dataAdmissao        String?              @db.VarChar(20)
  jornadaDiaria       Int?
  escala              String?              @db.VarChar(50)
  dataInicioEscala    String?              @db.VarChar(20)
  photoURL            String?              @db.Text
  role                perfis_role?         @default(user)
  nomeExportacao      String?              @db.VarChar(255)
  lastSeen            BigInt?
  config              String?              @db.LongText
  historicoProgressao String?              @db.LongText
  createdAt           DateTime?            @default(now()) @db.Timestamp(0)
  updatedAt           DateTime?            @default(now()) @db.Timestamp(0)
  holerites           holerites[]
  lancamentos         lancamentos[]
  pontos              pontos[]
  support_tickets     support_tickets[]
  user_theme_settings user_theme_settings?
}

model pokemon_collections {
  id             Int      @id @default(autoincrement())
  userId         String   @db.VarChar(50)
  setId          String   @db.VarChar(100)
  cardId         String   @db.VarChar(100)
  instanceId     String   @unique(map: "instanceId") @db.VarChar(50)
  price          Decimal? @default(0.0000) @db.Decimal(10, 4)
  addedAt        BigInt
  card_condition String?  @default("NM") @db.VarChar(20)
  card_variant   String?  @default("Normal") @db.VarChar(30)

  @@index([userId, setId], map: "idx_setId")
  @@index([userId], map: "idx_userId")
}

model pontos {
  id               Int       @id @default(autoincrement())
  userId           String?   @db.VarChar(128)
  data             String?   @db.VarChar(10)
  entrada          String?   @db.VarChar(5)
  saidaAlmoco      String?   @db.VarChar(5)
  voltaAlmoco      String?   @db.VarChar(5)
  saida            String?   @db.VarChar(5)
  horasTrabalhadas Decimal?  @db.Decimal(5, 2)
  saldoDiario      Decimal?  @db.Decimal(5, 2)
  temDireitoJanta  Boolean?  @default(false)
  createdAt        DateTime? @default(now()) @db.Timestamp(0)
  perfis           perfis?   @relation(fields: [userId], references: [uid], onDelete: Cascade, onUpdate: Restrict, map: "pontos_ibfk_1")

  @@unique([userId, data], map: "unique_ponto")
}

model support_tickets {
  id             Int                             @id @default(autoincrement())
  userId         String?                         @db.VarChar(128)
  userName       String?                         @db.VarChar(255)
  classification support_tickets_classification?
  subject        String?                         @db.VarChar(255)
  message        String?                         @db.Text
  status         support_tickets_status?         @default(open)
  createdAt      DateTime?                       @default(now()) @db.Timestamp(0)
  app_name       String?                         @default("contracheque") @db.VarChar(50)
  perfis         perfis?                         @relation(fields: [userId], references: [uid], onDelete: Cascade, onUpdate: Restrict, map: "support_tickets_ibfk_1")

  @@index([userId], map: "userId")
}

model two_factor_codes {
  id        Int    @id @default(autoincrement())
  userId    Int
  code      String @db.VarChar(6)
  expiresAt BigInt
  attempts  Int?   @default(0)
}

model user_price_alerts {
  id            Int       @id @default(autoincrement())
  user_id       String    @db.VarChar(128)
  session_id    String?   @db.VarChar(100)
  alerted_at    DateTime? @default(now()) @db.Timestamp(0)
  cards_changed Int?      @default(0)
  alert_data    String?   @db.LongText
  seen          Boolean?  @default(false)

  @@index([user_id, seen], map: "idx_user_alerts")
}

model user_theme_settings {
  id                 Int                                   @id @default(autoincrement())
  userId             String                                @unique(map: "userId") @db.VarChar(128)
  bg_color           String?                               @default("#020617") @db.VarChar(7)
  text_color         String?                               @default("#ffffff") @db.VarChar(7)
  card_bg_color      String?                               @default("#1e293b") @db.VarChar(7)
  card_border_color  String?                               @default("#10b981") @db.VarChar(7)
  price_color        String?                               @default("#3b82f6") @db.VarChar(7)
  btn_add_color      String?                               @default("#3b82f6") @db.VarChar(7)
  btn_remove_color   String?                               @default("#10b981") @db.VarChar(7)
  rarity_badge_color String?                               @default("#1e293b") @db.VarChar(7)
  card_number_color  String?                               @default("#64748b") @db.VarChar(7)
  bg_image_url       String?                               @db.MediumText
  bg_image_style     user_theme_settings_bg_image_style?   @default(cover)
  bg_image_type      String?                               @default("color") @db.VarChar(20)
  updated_at         DateTime?                             @default(now()) @db.Timestamp(0)
  panel_bg_color     String?                               @default("#0f172a") @db.VarChar(7)
  panel_opacity      Int?                                  @default(50)
  aba_bg_color       String?                               @default("#1e293b") @db.VarChar(7)
  aba_text_color     String?                               @default("#ffffff") @db.VarChar(7)
  theme_brightness   user_theme_settings_theme_brightness? @default(dark)
  perfis             perfis                                @relation(fields: [userId], references: [uid], onDelete: Cascade, onUpdate: Restrict, map: "user_theme_settings_ibfk_1")
}

model usuarios {
  id                 Int            @id @default(autoincrement())
  username           String         @unique(map: "username") @db.VarChar(100)
  email              String?        @unique(map: "email") @db.VarChar(255)
  password_hash      String         @db.VarChar(255)
  nome               String?        @db.VarChar(255)
  role               usuarios_role? @default(user)
  ativo              Boolean?       @default(true)
  createdAt          DateTime?      @default(now()) @db.Timestamp(0)
  updatedAt          DateTime?      @default(now()) @db.Timestamp(0)
  failed_attempts    Int?           @default(0)
  locked_until       BigInt?
  two_factor_enabled Boolean?       @default(false)

  @@index([email], map: "idx_email")
  @@index([username], map: "idx_username")
}

enum lancamentos_tipo {
  receita
  despesa
}

enum support_tickets_classification {
  Boa_sugest_o @map("Boa sugestão")
  Mal_sugest_o @map("Mal sugestão")
}

enum usuarios_role {
  admin
  user
}

enum support_tickets_status {
  open
  closed
}

enum perfis_role {
  admin
  user
}

enum user_theme_settings_bg_image_style {
  cover
  stretch
  tile
  original
}

enum user_theme_settings_theme_brightness {
  dark
  light
}
