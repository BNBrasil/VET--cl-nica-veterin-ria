# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database
# Example: mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL=mysql://usuario:senha@localhost:3306/vet_clinic

# Auth
# Generate a strong random value before production.
VET_JWT_SECRET=troque-esta-chave-em-producao
VET_JWT_EXPIRES_IN=7d

# Mail
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# Frontend
# Leave empty for same-origin API, or set to your backend URL.
VITE_API_BASE_URL=
